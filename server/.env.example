# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration - MongoDB Atlas
# For local development with MongoDB Atlas:
# 1. Create a cluster on MongoDB Atlas (https://www.mongodb.com/cloud/atlas)
# 2. Create a database user with a strong password
# 3. Get your connection string from the Atlas dashboard
# 4. Update the real .env file with your actual connection string:
#    MONGO_URI=mongodb+srv://payrolladmin:<password>@cluster0.xxxxx.mongodb.net/payroll
#
# IMPORTANT: Never commit the real .env file (it should be in .gitignore)
# Only commit this example file with placeholder values

MONGO_URI=mongodb+srv://username:pay@7373@cluster0.xxxxx.mongodb.net/payroll

# File Upload Configuration
MAX_FILE_SIZE=52428800  # 50MB in bytes

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
