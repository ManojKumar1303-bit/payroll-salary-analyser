# Environment example for Payroll Management System

# SERVER
# Port the backend listens on (Render will override automatically)
PORT=5000
# URL of the frontend application (used for CORS)
FRONTEND_URL=https://your-vercel-domain.vercel.app

# CLIENT
# Base URL for API requests from the React app
VITE_API_URL=https://your-render-backend-url.com/api

# Debug flags (optional)
#DEBUG_PARSE=true
#DEBUG_SALARY=true
